<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <div class="col-12 col-md-8 offset-md-2">
        <h3 class="mb-4 text-center">Create a New Listing</h3>
        <form action="/listings" method="post" class="needs-validation" novalidate enctype="multipart/form-data">

            <!-- Title -->
            <div class="mb-3 d-flex d-md-block align-items-center">
                <label for="title" class="me-2" style="min-width: 100px;">Title</label>
                <input type="text" name="listing[title]" placeholder="Add a catchy title" class="form-control flex-grow-1" required>
                <div class="valid-feedback">Title looks good!</div>
            </div>

            <!-- Description -->
            <div class="mb-3 d-flex d-md-block align-items-start">
                <label for="description" class="me-2" style="min-width: 100px;">Description</label>
                <textarea name="listing[description]" class="form-control flex-grow-1" required></textarea>
                <div class="invalid-feedback">Please enter a short description!</div>
            </div>

            <!-- Image -->
            <div class="mb-3 d-flex d-md-block align-items-center">
                <label for="image" class="me-2" style="min-width: 100px;">Upload Listing Image</label>
                <input type="file" name="listing[image]" class="form-control flex-grow-1" required>
            </div>

            <!-- Price & Country -->
            <div class="row">
                <div class="mb-3 col-12 col-md-4 d-flex d-md-block align-items-center">
                    <label for="price" class="me-2" style="min-width: 80px;">Price</label>
                    <input name="listing[price]" placeholder="1200" class="form-control flex-grow-1" required>
                    <div class="invalid-feedback">Price should be valid!</div>
                </div>

                <div class="mb-3 col-12 col-md-8 d-flex d-md-block align-items-center">
                    <label for="country" class="me-2" style="min-width: 100px;">Country</label>
                    <input type="text" name="listing[country]" placeholder="India" class="form-control flex-grow-1" required>
                    <div class="invalid-feedback">Country name should be valid!</div>
                </div>
            </div>

            <!-- Location -->
            <div class="mb-3 d-flex d-md-block align-items-center">
                <label for="location" class="me-2" style="min-width: 100px;">Location</label>
                <input type="text" name="listing[location]" placeholder="Jaipur, Rajasthan" class="form-control flex-grow-1" required>
                <div class="invalid-feedback">Location should be valid!</div>
            </div>

            <!-- Centered Button -->
            <div class="d-flex justify-content-center mt-4 mb-4">
                <button class="btn btn-dark add-btn">Add</button>
            </div>

        </form>
    </div>
</div>